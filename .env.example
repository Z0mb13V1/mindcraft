# Discord Bot Configuration
# Get your bot token from: https://discord.com/developers/applications/YOUR_APP_ID/bot
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Admin Authorization: comma-separated Discord user IDs allowed to run
# destructive bot commands (!start, !stop, !restart, !mode, etc.).
# Find your user ID: Discord Settings → Advanced → Developer Mode, then right-click your name.
# If left empty, all destructive commands will be blocked for everyone.
DISCORD_ADMIN_IDS=your_discord_user_id_here

# Discord Webhooks
# Create webhooks in Discord: Server Settings → Integrations → Webhooks
BACKUP_WEBHOOK_URL=your_webhook_url_here

# Discord Channel IDs
BOT_DM_CHANNEL=your_bot_dm_channel_id_here
BACKUP_CHAT_CHANNEL=your_backup_channel_id_here

# ── LLM API Keys ─────────────────────────────────────────────
# These replace keys.json. Environment variables take priority.
OPENAI_API_KEY=
OPENAI_ORG_ID=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
REPLICATE_API_KEY=
GROQCLOUD_API_KEY=
HUGGINGFACE_API_KEY=
QWEN_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
GHLF_API_KEY=
HYPERBOLIC_API_KEY=
NOVITA_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
MERCURY_API_KEY=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=

# MindServer Configuration
# Use actual Docker container name (check with: docker ps)
MINDSERVER_HOST=mindcraft-agents
MINDSERVER_PORT=8080

# NAS Configuration (for backup scripts)
NAS_SSH_HOST=your_nas_ip_here
NAS_SSH_USER=your_nas_username
NAS_SSH_KEY_PATH=$HOME/.ssh/nas_key

# Optional: Minecraft Server
MINECRAFT_HOST=your_minecraft_server_ip
MINECRAFT_PORT=25565

# ── Infrastructure (EC2 / Tailscale / LiteLLM) ─────────────────
# These are only needed for the EC2 hybrid rig deployment.
EC2_PUBLIC_IP=
TAILSCALE_AUTHKEY=
OLLAMA_TAILSCALE_IP=your_tailscale_ip_here
LITELLM_MASTER_KEY=your_litellm_key_here
VLLM_BASE_URL=http://host.docker.internal:8000/v1
GITHUB_TOKEN=

# Public hostname used by discord-bot for viewer URLs
PUBLIC_HOST=

# ── Runtime Overrides (optional) ─────────────────────────────
# PROFILES=["./profiles/ensemble.json"]
# INSECURE_CODING=false
# MAX_MESSAGES=100
# NUM_EXAMPLES=2
# LOG_ALL=false
# BLOCKED_ACTIONS=["!newAction"]
# SETTINGS_JSON={}

# Instructions:
# 1. Copy this file to '.env' in the project root
# 2. Replace all 'your_*_here' values with actual credentials
# 3. NEVER commit the .env file to Git
# 4. The .env file is already in .gitignore for protection
