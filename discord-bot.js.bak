import { Client, ChannelType, REST, Routes, GatewayIntentBits } from 'discord.js';
import { io } from 'socket.io-client';

// All secrets must be provided via environment variables
const BOT_TOKEN = process.env.DISCORD_BOT_TOKEN;
const BOT_DM_CHANNEL = process.env.BOT_DM_CHANNEL;
const BACKUP_CHAT_CHANNEL = process.env.BACKUP_CHAT_CHANNEL;
const MINDSERVER_HOST = process.env.MINDSERVER_HOST || 'mindcraft';
const MINDSERVER_PORT = process.env.MINDSERVER_PORT || 8080;

if (!BOT_TOKEN) {
    console.error('❌ DISCORD_BOT_TOKEN environment variable is required');
    process.exit(1);
}

const client = new Client({ 
    intents: [
        GatewayIntentBits.Guilds,
        GatewayIntentBits.GuildMessages,
        GatewayIntentBits.MessageContent,
        GatewayIntentBits.DirectMessages,
        GatewayIntentBits.DirectMessageTyping
    ]
});

let mindServerSocket = null;

// Connect to MindServer
async function connectToMindServer() {
    return new Promise((resolve, reject) => {
        mindServerSocket = io(`http://${MINDSERVER_HOST}:${MINDSERVER_PORT}`, {
            reconnection: true,
            reconnectionDelay: 1000,
            reconnectionDelayMax: 5000,
            reconnectionAttempts: 5
        });

        mindServerSocket.on('connect', () => {
            console.log('✅ Connected to MindServer');
            resolve();
        });

        mindServerSocket.on('disconnect', () => {
            console.log('⚠️  Disconnected from MindServer');
        });

        mindServerSocket.on('bot-output', (agentName, message) => {
            console.log(`[MindServer] ${agentName}: ${message}`);
            relayToDiscord(message);
        });

        mindServerSocket.on('chat-message', (agentName, json) => {
            console.log(`[MindServer Chat] ${agentName}: ${JSON.stringify(json)}`);
            if (json.message) {
                relayToDiscord(`**${agentName}**: ${json.message}`);
            }
        });

        mindServerSocket.on('connect_error', (error) => {
            console.error('Connection error:', error);
            reject(error);
        });

        setTimeout(() => reject(new Error('MindServer connection timeout')), 5000);
    });
}

// Relay message to Discord
async function relayToDiscord(message) {
    try {
        const channel = await client.channels.fetch(BOT_DM_CHANNEL);
        if (channel) {
            await channel.send(message.substring(0, 2000)); // Discord 2000 char limit
        }
    } catch (error) {
        console.error('Error sending to Discord:', error);
    }
}

// Send message to MindServer
function sendToMindServer(message, userId) {
    if (!mindServerSocket || !mindServerSocket.connected) {
        console.error('Not connected to MindServer');
        return;
    }

    // Get first agent from MindServer
    mindServerSocket.emit('send-message', {
        from: userId,
        message: message
    });
}

client.on('clientReady', () => {
    console.log(`🤖 Discord bot logged in as ${client.user.tag}`);
});

client.on('messageCreate', async (message) => {
    console.log(`DEBUG messageCreate: author=${message.author.tag} (id=${message.author.id}), channel=${message.channelId} (type=${message.channel.type}), content=${message.content || '[NO CONTENT]'} (bot? ${message.author.bot})`);

    // Ignore bot's own messages
    if (message.author.id === client.user.id) {
        console.log('DEBUG: Ignoring own message');
        return;
    }

    const isVerbotDM = message.channelId === BOT_DM_CHANNEL;
    const isBackupChat = message.channelId === BACKUP_CHAT_CHANNEL;
    console.log(`DEBUG: isVerbotDM=${isVerbotDM}, isBackupChat=${isBackupChat}`);

    if (!isVerbotDM && !isBackupChat) {
        console.log('DEBUG: Ignoring non-target channel');
        return;
    }

    console.log(`[Discord] ${message.author.username}: ${message.content}`);

    try {
        // Echo test response
        await message.reply(`Echo test: ${message.content}`);
        
        // Send typing indicator
        await message.channel.sendTyping();

        // Relay to MindServer
        sendToMindServer(message.content, message.author.id);

        // Acknowledge (optional)
        if (isVerbotDM) {
            await message.react('✅');
        }
    } catch (error) {
        console.error('Error processing message:', error);
        await message.reply('❌ Error processing your message.');
    }
});

client.on('error', (error) => {
    console.error('Discord client error:', error);
});

// Start the bot
async function start() {
    try {
        console.log('🚀 Starting Discord bot...');
        await client.login(BOT_TOKEN);

        // Wait a bit for client to be ready
        await new Promise(resolve => setTimeout(resolve, 2000));

        console.log('📡 Connecting to MindServer...');
        connectToMindServer().catch(error => {
            console.error('MindServer connection failed, continuing without:', error);
        });

        console.log('✅ Discord bot fully initialized');
    } catch (error) {
        console.error('Failed to start Discord bot:', error);
        process.exit(1);
    }
}

start();

// Graceful shutdown
process.on('SIGINT', async () => {
    console.log('\n🛑 Shutting down...');
    if (mindServerSocket) {
        mindServerSocket.disconnect();
    }
    await client.destroy();
    process.exit(0);
});
