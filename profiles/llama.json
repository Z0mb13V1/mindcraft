{
    "name": "LLama",
    "model": "groq/llama-3.3-70b-versatile",
    "max_tokens": 4000,
    "embedding": "openai",
    "_active_mode": "cloud",
    "_modes": {
        "cloud": {
            "model": "groq/llama-3.3-70b-versatile",
            "compute_type": "Cloud-based",
            "embedding": "openai"
        },
        "local": {
            "model": {
                "api": "vllm",
                "model": "Qwen/Qwen2.5-7B-Instruct",
                "url": "http://host.docker.internal:8000/v1"
            },
            "compute_type": "Local (vLLM)",
            "embedding": {
                "api": "google",
                "model": "gemini-embedding-001"
            }
        },
        "hybrid": {
            "model": "groq/llama-3.3-70b-versatile",
            "code_model": {
                "api": "vllm",
                "model": "Qwen/Qwen2.5-7B-Instruct",
                "url": "http://host.docker.internal:8000/v1"
            },
            "compute_type": "Hybrid (Cloud chat + vLLM code)",
            "embedding": "openai"
        }
    }
}
