{
    "name": "Mistral",
    "model": "mistral/mistral-large-latest",
    "_active_mode": "cloud",
    "_modes": {
        "cloud": {
            "model": "mistral/mistral-large-latest",
            "compute_type": "Cloud-based"
        },
        "local": {
            "model": {
                "api": "vllm",
                "model": "google/gemma-3-12b-it",
                "url": "http://host.docker.internal:8000/v1"
            },
            "compute_type": "Local (vLLM)",
            "embedding": {
                "api": "google",
                "model": "gemini-embedding-001"
            }
        },
        "hybrid": {
            "model": "mistral/mistral-large-latest",
            "code_model": {
                "api": "vllm",
                "model": "google/gemma-3-12b-it",
                "url": "http://host.docker.internal:8000/v1"
            },
            "compute_type": "Hybrid (Cloud chat + vLLM code)"
        }
    }
}
